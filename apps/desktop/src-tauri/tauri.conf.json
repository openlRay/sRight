{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "sRight",
    "version": "0.1.0",
    "identifier": "dev.sright.preferences",
    "build": {
        "beforeDevCommand": "pnpm dev",
        "beforeBuildCommand": "pnpm build",
        "devUrl": "http://127.0.0.1:1420",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
      {
        "label": "main",
        "title": "sRight Preferences",
        "width": 900,
        "height": 720,
                "minWidth": 640,
                "minHeight": 520
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
    "active": true,
    "targets": "app",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.png"
    ]
  }
}
